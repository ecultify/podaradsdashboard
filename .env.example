# Copy to .env.local and fill in.

# Meta app credentials (only needed for the token-exchange route)
META_APP_ID=
META_APP_SECRET=

# Long-lived Meta access token with read access to the ad account below
META_ACCESS_TOKEN=

# Ad account id, including the act_ prefix (from the Ads Manager URL ?act=...)
META_AD_ACCOUNT_ID=act_

# Website-leads campaign id to track
META_CAMPAIGN_ID_WEBSITE_LEADS=

# Ad sets under the campaign (comma-separated, order = display order). Optional —
# leave blank to auto-discover every ad set under the campaign.
META_ADSET_IDS=

# Server-side cache TTL (seconds) for Meta responses. Reloading the page within
# this window serves cached data instead of re-hitting Meta (avoids rate limits).
META_CACHE_TTL_SECONDS=300

NEXT_PUBLIC_APP_URL=http://localhost:3000
