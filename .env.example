# Copy to .env.local and fill in. See public/manual-values.json for manual KPI overrides.

META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

META_CAMPAIGN_NAME_FILTER=
NEXT_PUBLIC_META_CAMPAIGN_NAME_FILTER=

# Optional: manual numbers (override Sheet + public/manual-values.json).
# MANUAL_TOTAL_AMOUNT=1035000
# MANUAL_AMOUNT_SPENT=564732.93
# MANUAL_LINK_CLICKS=474000
# MANUAL_BALANCE_LEFT=0

# Google Sheet (CSV export). Share sheet as “Anyone with the link” viewer.
# GOOGLE_SHEET_ID=paste_from_spreadsheet_url
# GOOGLE_SHEET_GID=0
# Or full URL:
# GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0

META_CAMPAIGN_ID_CONVERSATIONS=
META_CAMPAIGN_ID_WEBSITE_LEADS=
META_CAMPAIGN_ID_LINK_CLICKS=

NEXT_PUBLIC_REFRESH_INTERVAL=300
