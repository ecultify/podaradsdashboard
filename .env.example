# Copy to .env.local and fill in.

# Meta app credentials (only needed for the token-exchange route)
META_APP_ID=
META_APP_SECRET=

# Long-lived Meta access token with read access to the ad account below
META_ACCESS_TOKEN=

# Ad account id, including the act_ prefix (from the Ads Manager URL ?act=...)
META_AD_ACCOUNT_ID=act_

# Website-leads campaign id to track
META_CAMPAIGN_ID_WEBSITE_LEADS=

# Ad sets under the campaign (comma-separated, order = display order). Optional —
# leave blank to auto-discover every ad set under the campaign.
META_ADSET_IDS=

# Server-side cache TTL (seconds) for Meta responses. Reloading the page within
# this window serves cached data instead of re-hitting Meta (avoids rate limits).
META_CACHE_TTL_SECONDS=300

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Ads tab (reads from a public Google Sheet populated by Apps Script) ---
# Spreadsheet id from the sheet URL (/spreadsheets/d/<ID>/edit). The sheet must be
# shared "Anyone with the link can view". Defaults to the Podar sheet if blank.
GOOGLE_SHEET_ID=
# Tab names within the spreadsheet (defaults: Summary / Campaigns)
GOOGLE_SHEET_SUMMARY_TAB=Summary
GOOGLE_SHEET_CAMPAIGNS_TAB=Campaigns
# Currency the sheet's cost values are in (display only)
GOOGLE_ADS_CURRENCY=INR

# --- Budgets & billing multiplier (optional; defaults baked into code) ---
# Total budgets in INR and the multiplier applied to raw ad spend to get the
# billed amount. Balance = budget − (raw spend × multiplier).
META_BUDGET_INR=156250.003
GOOGLE_BUDGET_INR=66964.287
SPEND_MULTIPLIER=4.5
